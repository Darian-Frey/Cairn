{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Darian-Frey/Cairn/schemas/projects/lumina.json",
  "title": "CAIRN_V1 — Lumina extension",
  "description": "Project-specific fields for Lumina (PyQt6 physics / maths simulation suite).",
  "type": "object",
  "required": ["PROJ_EXT"],
  "properties": {
    "project": { "const": "lumina" },
    "PROJ_EXT": {
      "type": "object",
      "required": ["modules"],
      "additionalProperties": false,
      "properties": {
        "modules": {
          "type": "array",
          "description": "Simulation modules with topic and curriculum alignment.",
          "items": {
            "type": "object",
            "required": ["id", "name", "topic"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "topic": { "type": "string" },
              "curriculum_stage": {
                "type": "string",
                "description": "Stage identifier (e.g. 'KS4', 'A-level', 'undergrad')."
              },
              "completion_pct": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              }
            },
            "additionalProperties": false
          }
        },
        "curriculum_alignment": {
          "type": "string",
          "description": "Reference syllabus identifier (e.g. exam board code)."
        }
      }
    }
  }
}
